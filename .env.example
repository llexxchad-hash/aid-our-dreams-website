# ============================================
# Aid Our Dreams — Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
#
# NOTE: For this static frontend site, the Supabase ANON key
# is designed to be public. It is NOT a secret — Row Level Security
# (RLS) policies on the database protect your data. The anon key
# only grants the permissions you allow via RLS.
#
# The SERVICE_ROLE key IS secret and should NEVER be in frontend code.
# It is only needed for server-side admin operations.
# ============================================

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# DO NOT put the service_role key in any frontend file
# SUPABASE_SERVICE_ROLE_KEY=your-secret-service-role-key
